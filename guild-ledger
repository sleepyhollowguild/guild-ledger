function colorLabel(colors){colors=Array.isArray(colors)?colors:[]; if(!colors.length)return 'Colorless'; if(colors.length>1)return 'Multicolor'; return ({W:'White',U:'Blue',B:'Black',R:'Red',G:'Green'}[colors[0]]||colors[0])}
function typeGroups(typeLine){const t=String(typeLine||''); const groups=[]; if(/Legendary/i.test(t)) groups.push('Legendary'); ['Creature','Artifact','Enchantment','Instant','Sorcery','Land','Planeswalker','Battle'].forEach(x=>{if(new RegExp(x,'i').test(t))groups.push(x)}); if(/Token/i.test(t))groups.push('Token'); if(!groups.length)groups.push('Other'); return groups}
function applyMeta(){CARD_DATA.forEach(c=>{const m=state.meta[c.scryfallId]; c.color=m?.color||'Unknown'; c.typeLine=m?.typeLine||''; c.typeGroups=m?.typeGroups||['Unknown']; if(m) c.search=(String(c.search||'')+' '+c.color+' '+c.typeLine+' '+c.typeGroups.join(' ')).toLowerCase();});}
function populateFilters(){const setEl=$('setFilter'); if(setEl.options.length<=1){[...new Map(CARD_DATA.map(c=>[c.setCode,`${c.setCode} — ${c.setName}`])).entries()].sort((a,b)=>a[1].localeCompare(b[1])).forEach(([code,label])=>{const o=document.createElement('option');o.value=code;o.textContent=label;setEl.appendChild(o)})} const has=CARD_DATA.some(c=>c.color&&c.color!=='Unknown'); if(has){const ce=$('colorFilter'), te=$('typeFilter'), cv=ce.value,tv=te.value; ce.innerHTML='<option value="all">Mana</option>'; ['White','Blue','Black','Red','Green','Multicolor','Colorless'].forEach(x=>ce.add(new Option(x,x))); te.innerHTML='<option value="all">Relic Type</option>'; ['Creature','Legendary','Artifact','Enchantment','Instant','Sorcery','Land','Planeswalker','Battle','Token','Other'].forEach(x=>te.add(new Option(x,x))); if([...ce.options].some(o=>o.value===cv)) ce.value=cv; if([...te.options].some(o=>o.value===tv)) te.value=tv;} $('metaPill').textContent=has?`${Object.keys(state.meta).length.toLocaleString()} Scryfall records cached`:'Mana/type filters need sync';}
async function syncMeta(){const ids=[...new Set(CARD_DATA.map(c=>c.scryfallId).filter(Boolean))].filter(id=>!state.meta[id]); if(!ids.length){toast('Mana/type filters already loaded');return} if(!confirm(`Load Mana and type data for ${ids.length.toLocaleString()} cards? This needs internet once and caches on the iPad.`))return; $('syncBtn').textContent='Consulting Scryfall…'; for(let i=0;i<ids.length;i+=75){const chunk=ids.slice(i,i+75); try{const r=await fetch('https://api.scryfall.com/cards/collection',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({identifiers:chunk.map(id=>({id}))})}); const j=await r.json(); (j.data||[]).forEach(card=>{state.meta[card.id]={color:colorLabel(card.colors), typeLine:card.type_line, typeGroups:typeGroups(card.type_line)}}); localStorage.setItem('wt_scryfall_meta_v1',JSON.stringify(state.meta)); $('metaPill').textContent=`Loaded ${Object.keys(state.meta).length.toLocaleString()} records…`; await new Promise(res=>setTimeout(res,120));}catch(e){alert('Scryfall sync failed. Check internet and try again.');break}} $('syncBtn').textContent='Load Mana/Type Filters'; applyMeta(); populateFilters(); render();}
function tierLabel(t){return t==='Bulk'?'Common Stock':t==='$1 Binder'?'Merchant Shelf':t==='Showcase'?'Curiosities Cabinet':t}
function filtered(){
  const q=$('q').value.trim().toLowerCase();
  const tier=$('tier').value, finish=$('finish').value, set=$('setFilter').value, color=$('colorFilter').value, type=$('typeFilter').value;
  let arr=CARD_DATA.filter(c=>{
    const hay=((c.search||'')+' '+(c.name||'')+' '+(c.setName||'')+' '+(c.setCode||'')).toLowerCase();
    if(q && !hay.includes(q)) return false;
    if(tier!=='all' && c.tier!==tier) return false;
    if(finish!=='all' && c.foil!==finish) return false;
    if(set!=='all' && c.setCode!==set) return false;
    if(color!=='all' && (c.color||'Unknown')!==color) return false;
    if(type!=='all' && !(c.typeGroups||[]).includes(type)) return false;
    return true;
  });
  return sortCards(arr);
}
function sortCards(arr){
  const mode=$('sort').value;
  const price=n=>Number(n.salePrice||0);
  const name=n=>String(n.name||'').toLowerCase();
  const qty=n=>Number(n.quantity||0);
  return [...arr].sort((a,b)=>{
    if(mode==='priceDesc') return (price(b)-price(a)) || name(a).localeCompare(name(b));
    if(mode==='priceAsc') return (price(a)-price(b)) || name(a).localeCompare(name(b));
    if(mode==='qtyDesc') return (qty(b)-qty(a)) || name(a).localeCompare(name(b));
    return name(a).localeCompare(name(b));
  });
}
function render(){const arr=filtered(); $('cards').innerHTML=arr.map(cardHtml).join(''); $('empty').classList.toggle('hidden',arr.length!==0); $('countPill').textContent=`${arr.length.toLocaleString()} records shown`; const total=CARD_DATA.reduce((a,c)=>a+(Number(c.quantity)||0),0); $('summaryPill').textContent=`${total.toLocaleString()} cards in the ledger`; renderCart();}
function esc(s){return String(s??'').replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]))}
function imgUrl(c,version='normal'){return String(c.image||'').replace(/version=(small|normal|large|png)/,'version='+version)}
function cardHtml(c){const price=money(c.salePrice); const cls=c.tier==='Showcase'?'record showcase':'record'; return `<article class="${cls}" onclick="inspect('${esc(c.key)}')"><div class="recordTop"><img class="thumb" loading="lazy" src="${esc(imgUrl(c,'normal'))}" onerror="this.style.display='none'"/><div><div class="cardName">${esc(c.name)} <span class="tiny">[${esc(c.setCode)} #${esc(c.collector)}]</span></div><div class="meta">${esc(c.setName)}<br>${esc(c.condition)} • ${esc(c.foil)} • Qty ${c.quantity}</div><div class="badgeRow"><span class="badge tier ${c.tier==='Showcase'?'showcase':''}">${tierLabel(c.tier)}</span><span class="badge">${esc(c.rarity||'')}</span>${c.color&&c.color!=='Unknown'?`<span class="badge">${esc(c.color)}</span>`:''}</div><div class="price">${price}</div></div></div><div class="recordActions"><button onclick="event.stopPropagation();addToCart('${esc(c.key)}')">Add to Pack</button><button class="ghost" onclick="event.stopPropagation();inspect('${esc(c.key)}')">Inspect</button></div></article>`}
function findCard(key){return CARD_DATA.find(c=>c.key===key)}
function addToCart(key){const c=findCard(key); if(!c)return; const cur=state.cart[key]||0; if(cur>=c.quantity){toast('No more copies available in ledger');return} state.cart[key]=cur+1; saveCart(); renderCart(); toast('Added to Trader\'s Pack')}
function changeQty(key,d){const c=findCard(key); let q=(state.cart[key]||0)+d; if(q<=0) delete state.cart[key]; else state.cart[key]=Math.min(q,c?.quantity||q); saveCart(); renderCart()}
function saveCart(){localStorage.setItem('guild_cart_v1',JSON.stringify(state.cart))}
function cartItems(){return Object.entries(state.cart).map(([key,qty])=>({card:findCard(key),qty})).filter(x=>x.card&&x.qty>0)}
function totals(){const items=cartItems(); const bulkQty=items.filter(x=>x.card.tier==='Bulk').reduce((a,x)=>a+x.qty,0); let subtotal=0, bulkFull=0, bulkDiscount=0; items.forEach(({card,qty})=>{let p=Number(card.salePrice)||0; if(card.tier==='Bulk'){bulkFull += qty*p; subtotal += qty*(bulkQty>=4?0.25:p)} else subtotal += qty*p}); if(bulkQty>=4) bulkDiscount=bulkFull-(bulkQty*0.25); return {subtotal,bulkQty,bulkDiscount,count:items.reduce((a,x)=>a+x.qty,0)}}
function renderCart(){const items=cartItems(); const relicCount = items.reduce((a,x)=>a+x.qty,0); $('packCount').textContent = relicCount === 0 ? 'Pack: Empty' : `Pack: ${relicCount} ${relicCount === 1 ? 'Relic' : 'Relics'}`; $('cartLines').innerHTML=items.length?items.map(({card,qty})=>`<div class="line"><div class="lineName">${esc(card.name)} × ${qty}</div><div class="tiny">${esc(card.setCode)} #${esc(card.collector)} • ${esc(card.condition)} • ${esc(card.foil)} • ${tierLabel(card.tier)} • ${money(card.salePrice)}</div><div class="qty"><button onclick="changeQty('${esc(card.key)}',-1)">−</button><span>${qty}</span><button onclick="changeQty('${esc(card.key)}',1)">+</button></div></div>`).join(''):'<div class="empty">Your Trader\'s Pack is empty.</div>'; const t=totals(); $('totals').innerHTML=items.length?`Total for Square: ${money(t.subtotal)}${t.bulkDiscount>0?`<div class="tiny">Bulk 4+ discount applied: −${money(t.bulkDiscount)}</div>`:''}`:'Pack empty.'; renderPullList(items); $('historyCount').textContent=`${state.sales.reduce((a,x)=>a+Number(x.quantity||0),0)} sold cards recorded today`;}
function pullSorted(items=cartItems()){const rank={'Showcase':0,'$1 Binder':1,'Bulk':2}; return [...items].sort((a,b)=>(rank[a.card.tier]??9)-(rank[b.card.tier]??9)||String(a.card.location||'').localeCompare(String(b.card.location||''))||a.card.name.localeCompare(b.card.name))}
function renderPullList(items=cartItems()){$('pullList').innerHTML=items.length?pullSorted(items).map(({card,qty},i)=>`<div class="pullItem"><b>${i+1}. ${esc(card.name)} × ${qty}</b><div class="tiny">${esc(card.location||tierLabel(card.tier))} • ${esc(card.setCode)} #${esc(card.collector)} • ${esc(card.condition)} / ${esc(card.foil)}</div></div>`).join(''):'<div class="tiny">No retrieval quest yet.</div>'}
function pullText(){const t=totals(); const lines=[`Sleepy Hollow Guild - Pull List`,`Total for Square: ${money(t.subtotal)}`,``,`Pull Order:`]; pullSorted().forEach(({card,qty},i)=>lines.push(`${i+1}. ${card.name} x${qty} — ${card.setCode} #${card.collector} — ${card.condition}/${card.foil} — ${card.location||tierLabel(card.tier)} — ${money(card.salePrice)}`)); return lines.join('\n')}
async function checkout(){if(!cartItems().length){toast('Pack is empty');return} const text=pullText(); try{if(navigator.share){await navigator.share({title:'Guild Pull List',text});}else if(navigator.clipboard){await navigator.clipboard.writeText(text); alert('Pull list copied. Paste/send it to your iPhone.')} }catch(e){} if(confirm('Record this sale in the end-of-day report?')){const stamp=new Date().toISOString(); cartItems().forEach(({card,qty})=>state.sales.push({soldAt:stamp,manaBoxId:card.id,scryfallId:card.scryfallId,name:card.name,setCode:card.setCode,setName:card.setName,collector:card.collector,foil:card.foil,condition:card.condition,quantity:qty,tier:card.tier,priceEach:card.salePrice,total:(Number(card.salePrice)||0)*qty})); localStorage.setItem('guild_sales_v1',JSON.stringify(state.sales)); state.cart={}; saveCart(); renderCart(); toast('Sale recorded')}}
function clearCart(){if(confirm('Clear Trader\'s Pack?')){state.cart={};saveCart();renderCart()}}
function exportSales(){if(!state.sales.length){toast('No sales to export');return} const headers=['soldAt','manaBoxId','scryfallId','name','setCode','setName','collector','foil','condition','quantity','tier','priceEach','total']; const csv=[headers.join(',')].concat(state.sales.map(r=>headers.map(h=>`"${String(r[h]??'').replace(/"/g,'""')}"`).join(','))).join('\n'); const blob=new Blob([csv],{type:'text/csv'}); const a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download='sleepy_hollow_sold_cards_'+new Date().toISOString().slice(0,10)+'.csv'; a.click(); URL.revokeObjectURL(a.href)}
function clearSales(){if(confirm('Clear the staff sales report? Export first if you need it.')){state.sales=[];localStorage.setItem('guild_sales_v1','[]');renderCart()}}
function inspect(key){const c=findCard(key); if(!c)return; $('modalCard').innerHTML=`<div class="detail"><img src="${esc(imgUrl(c,'normal'))}" onerror="this.style.display='none'"/><div><h2>${esc(c.name)}</h2><div class="meta" style="font-size:15px">${esc(c.setName)} (${esc(c.setCode)} #${esc(c.collector)})<br>${esc(c.condition)} • ${esc(c.foil)} • ${esc(c.rarity||'')} • Qty ${c.quantity}</div><div class="badgeRow"><span class="badge tier ${c.tier==='Showcase'?'showcase':''}">${tierLabel(c.tier)}</span>${c.color&&c.color!=='Unknown'?`<span class="badge">${esc(c.color)}</span>`:''}${c.typeLine?`<span class="badge">${esc(c.typeLine)}</span>`:''}</div><div class="price" style="font-size:36px">${money(c.salePrice)}</div><div class="note">Location: ${esc(c.location||tierLabel(c.tier))}</div><div class="recordActions"><button onclick="addToCart('${esc(c.key)}');closeModal()">Add to Trader's Pack</button><button class="ghost" onclick="closeModal()">Close</button></div></div></div>`; $('modal').classList.remove('hidden')}
function closeModal(){$('modal').classList.add('hidden')}
function toggleStaff(){state.staff=!state.staff; document.body.classList.toggle('staffOn',state.staff); toast(state.staff?'Staff ledger opened':'Staff ledger hidden')}
['q','tier','finish','setFilter','colorFilter','typeFilter','sort'].forEach(id=>$(id).addEventListener('input',render)); $('syncBtn').onclick=syncMeta; $('checkoutBtn').onclick=checkout; $('clearBtn').onclick=clearCart; $('exportBtn').onclick=exportSales; $('clearHistoryBtn').onclick=clearSales; $('staffDot').onclick=toggleStaff; $('modal').addEventListener('click',e=>{if(e.target.id==='modal')closeModal()}); document.addEventListener('keydown',e=>{if(e.key==='Escape')closeModal()});
let pressTimer=null; $('staffActivator').addEventListener('pointerdown',()=>{pressTimer=setTimeout(toggleStaff,1100)}); ['pointerup','pointerleave','pointercancel'].forEach(ev=>$('staffActivator').addEventListener(ev,()=>clearTimeout(pressTimer)));
applyMeta(); populateFilters(); render();
</script>
