parent;border-color:rgba(157,141,85,.25);padding:0 0 12px;color:#f5eddd}.modal{position:fixed;inset:0;background:rgba(0,0,0,.7);display:grid;place-items:center;z-index:50;padding:20px}.modalCard{width:min(960px,96vw);max-height:90vh;overflow:auto;background:var(--paper);border:1px solid var(--gold);border-radius:24px;box-shadow:0 30px 80px rgba(0,0,0,.55);padding:18px}.detail{display:grid;grid-template-columns:260px 1fr;gap:18px}.detail img{width:100%;border-radius:16px}.detail h2{font-family:Georgia,serif;font-size:38px;line-height:1;margin:0 0 8px}.toast{position:fixed;left:50%;bottom:22px;transform:translateX(-50%);background:var(--forest);color:white;padding:12px 16px;border-radius:999px;box-shadow:0 12px 30px rgba(0,0,0,.35);z-index:80;opacity:0;pointer-events:none;transition:.18s}.toast.show{opacity:1}.mobilePack{display:none}
@media(max-width:980px){.toolbar{grid-template-columns:1fr 1fr}.toolbar input{grid-column:1/-1}.layout{grid-template-columns:1fr}.pack{position:relative;top:0;max-height:none}.mobilePack{display:inline-block}.detail{grid-template-columns:1fr}.detail img{max-width:260px}.titleBlock h1{font-size:42px}.brandBar{align-items:flex-start}.sig{width:58px;height:58px;font-size:27px}}
