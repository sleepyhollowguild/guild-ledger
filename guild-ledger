.statusRow{display:flex;flex-wrap:wrap;gap:8px;padding:0 22px 22px;align-items:center;position:relative}.seal{background:rgba(47,58,46,.1);border:1px solid rgba(47,58,46,.25);border-radius:999px;padding:8px 11px;color:var(--forest);font-size:12px}.seal.gold{background:rgba(157,141,85,.18);border-color:rgba(157,141,85,.35);color:#5d4f24}
